[user]
	name = Pavel Lozinsky
	email = pavel@lozinsky.dev
	signingkey = ~/.ssh/id_ed25519.pub

[gpg]
	format = ssh

[commit]
	gpgsign = true

[fetch]
	prune = true

[core]
	editor = zed --wait
	excludesfile = ~/.gitignore

[merge]
	tool = smerge

[mergetool "smerge"]
	cmd = smerge mergetool $BASE $LOCAL $REMOTE -o $MERGED
	trustExitCode = true
