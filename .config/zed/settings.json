{
  "file_finder": {
    "file_icons": false,
  },
  "agent_servers": {
    "github-copilot-cli": {
      "type": "custom",
      "command": "copilot",
      "args": ["--acp", "--stdio"]
    },
  },
  "diff_view_style": "unified",
  "use_system_window_tabs": true,
  "snippet_sort_order": "top",
  "auto_install_extensions": {
    "oxc": true,
    "html": true,
    "toml": true,
    "emmet": true,
    "codebook": true,
    "gatito-theme": true,
  },
  "edit_predictions": {
    "provider": "copilot",
    "mode": "subtle",
  },
  "agent": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5",
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "context_servers": {
    "playwright": {
      "command": "playwright-mcp",
      "args": ["--cdp-endpoint", "http://localhost:9222"],
    },
    "chrome-devtools": {
      "command": "chrome-devtools-mcp",
      "args": ["--no-usage-statistics", "--auto-connect"],
    },
    "context7": {
      "command": "mcp-keychain",
      "args": [
        "mcp.context7.api-key",
        "mcp-remote",
        "https://mcp.context7.com/mcp",
        "--header",
        "CONTEXT7_API_KEY: {}",
      ],
    },
    "github": {
      "command": "mcp-keychain",
      "args": [
        "mcp.github.personal-access-token",
        "mcp-remote",
        "https://api.githubcopilot.com/mcp/readonly",
        "--header",
        "Authorization: Bearer {}",
      ],
    },
  },
  "collaboration_panel": {
    "button": false,
  },
  "current_line_highlight": "none",
  "diagnostics": {
    "button": false,
  },
  "debugger": {
    "button": false,
  },
  "buffer_font_family": "Maple Mono",
  "buffer_font_size": 14,
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "git_panel": {
    "button": false,
  },
  "gutter": {
    "breakpoints": false,
    "runnables": false,
  },
  "indent_guides": {
    "enabled": false,
  },
  "lsp": {
    "vscode-css-language-server": {
      "settings": {
        "css": {
          "lint": {
            "unknownAtRules": "ignore",
          },
        },
      },
    },
    "vtsls": {
      "settings": {
        "vtsls": {
          "experimental": {
            "completion": {
              "enableServerSideFuzzyMatch": true,
            },
          },
        },
        "typescript": {
          "tsserver": {
            "maxTsServerMemory": 16384,
          },
        },
      },
    },
  },
  "minimap": {
    "show": "never",
  },
  "notification_panel": {
    "button": false,
  },
  "project_panel": {
    "auto_fold_dirs": false,
    "entry_spacing": "standard",
    "file_icons": false,
    "folder_icons": false,
    "hide_root": true,
    "indent_guides": {
      "show": "never",
    },
    "indent_size": 8,
    "show_diagnostics": "off",
    "sticky_scroll": false,
  },
  "search": {
    "button": false,
  },
  "soft_wrap": "editor_width",
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "tab_size": 2,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "theme": "Gatito Dark",
  "title_bar": {
    "show_user_menu": false,
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
    "selections_menu": false,
  },
  "ui_font_family": "Google Sans Flex",
  "languages": {
    "CSS": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "HTML": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "JavaScript": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "JSON": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "JSONC": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "Markdown": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "TypeScript": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "TSX": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
    "YAML": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
      ],
    },
  },
}
