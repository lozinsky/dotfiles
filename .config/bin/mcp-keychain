#!/usr/bin/env bash

SERVICE="$1"
CMD="$2"

shift 2

SECRET=$(security find-generic-password -s "$SERVICE" -a "$USER" -w 2>/dev/null)

if [ -z "$SECRET" ]
then
  echo "Error: secret '$SERVICE' not found in Keychain." >&2
  echo "Add it with: security add-generic-password -s \"$SERVICE\" -a \"\$USER\" -w" >&2
  exit 1
fi

exec "$CMD" "${@//\{\}/$SECRET}"
