#!/usr/bin/env bash

should_brew_install() {
  ! brew list | grep "$1" >/dev/null
}

if should_brew_install starship
then
  brew install starship

  mkdir -p "$HOME/.config"

  ln -sf "$DOTFILES/.config/starship.toml" "$HOME/.config/starship.toml"
fi

if should_brew_install zsh-autosuggestions
then
  brew install zsh-autosuggestions
fi

if should_brew_install zsh-syntax-highlighting
then
  brew install zsh-syntax-highlighting
fi

if should_brew_install git
then
  brew install git

  ln -sf "$DOTFILES/.config/gitconfig" "$HOME/.gitconfig"
  ln -sf "$DOTFILES/.config/gitignore" "$HOME/.gitignore"
fi

if should_brew_install mise
then
  brew install mise

  mkdir -p "$HOME/.config/mise"

  ln -sf "$DOTFILES/.config/mise/config.toml" "$HOME/.config/mise/config.toml"
  ln -sf "$DOTFILES/.config/default-npm-packages" "$HOME/.default-npm-packages"
  ln -sf "$DOTFILES/.config/npmrc" "$HOME/.npmrc"
  ln -sf "$DOTFILES/.config/prettierrc" "$HOME/.prettierrc"

  mise -y install
fi

if should_brew_install rustup-init
then
  brew install rustup-init

  rustup-init -y --no-modify-path
fi

if should_brew_install docker
then
  brew install docker
fi

if should_brew_install colima
then
  brew install colima
  brew services start colima
fi

if should_brew_install mole
then
  brew install mole
fi
